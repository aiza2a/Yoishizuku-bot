BOT_TOKEN=
API_KEY=
BASE_URL=https://api.openai.com/v1/chat/completions
MODEL=deepseek-v4-flash-free
ADMIN_LIST=
GROUP_LIST=

# 可选：初始用户白名单。留空表示不启用用户白名单。
# whitelist=
# BLACK_LIST=
# CHAT_MODE=global
# NICK=
# NICK_ALIASES=
# LANGUAGE=Simplified Chinese

# === Yoishizuku-bot 本地化配置 ===
PERSONA_FILE=persona.env
MEMORY_DB_PATH=/home/memory_data/gptbot_memory.sqlite3
MEMORY_RECENT_TURNS=8
MEMORY_MAX_CONTEXT_CHARS=7000
MEMORY_SUMMARY_EVERY=8
ROLE_DATA_ROOT=/home/role_data
ACCESS_CONTROL_FILE=/home/access_data/access_control.json

# Telegram Bot API 10.0 富文本模式：表格、标题、LaTex、嵌入媒体等。
# 默认关闭，保持 MarkdownV2 兼容输出。
# RICH_MESSAGE=1
